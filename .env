# ==========================================================================
# REELZAK — Environment Variables
# ==========================================================================
# Copy this file to `.env` for local development, and configure the same
# keys in your Vercel project settings for production.
# --------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# LOCAL DEV (SQLite — works out of the box in this sandbox):
DATABASE_URL="file:./dev.db"

# PRODUCTION (Neon PostgreSQL — swap when deploying to Vercel):
# 1. Create a free DB at https://neon.tech
# 2. Copy the connection string ( pooled, e.g. .../neondb?sslmode=require )
# 3. Replace the line above with:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&connection_limit=1"
# 4. Also update `provider` in `prisma/schema.prisma` from "sqlite" to "postgresql"

# --- NextAuth -------------------------------------------------------------
# Used by NextAuth for JWT/session signing. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="reelzak-dev-secret-change-me-in-production"

# Public site URL — for NextAuth callbacks & email links.
# Local dev: http://localhost:3000
# Vercel prod: https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# --- File Storage (Phase 5 — Admin Uploads) -------------------------------
# We use Vercel Blob for storing delivered reel video files.
# Create at: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=""
